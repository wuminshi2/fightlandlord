{
  "name": "fight-landlord",
  "version": "1.0.0",
  "description": "A polished single-player Fight the Landlord desktop game built with Electron.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.fightlandlord.app",
    "productName": "斗地主",
    "directories": {
      "output": "build"
    },
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["zh_CN", "en_US"],
      "shortcutName": "斗地主"
    }
  }
}
